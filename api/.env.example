# --- NeuroSync API ---
PORT=4000

# Postgres (compose provides this automatically)
DATABASE_URL=postgresql://neurosync:neurosync@db:5432/neurosync

# Upstream Solana RPC. Kept server-side only and surfaced to the browser
# exclusively through the /rpc proxy. Use a Helius/QuickNode mainnet URL.
SOLANA_RPC=https://api.mainnet-beta.solana.com

# On-chain program id. Leave empty until the program is deployed, the API and
# site then run in "pre-launch" mode (browse works, registration is disabled).
PROGRAM_ID=

# Network + economics surfaced to the frontend via /config.
NETWORK=mainnet-beta
NAME_SUFFIX=.agent
TREASURY=
REGISTER_FEE_SOL=0.05

# Presence: an agent counts as "online" if it pinged within this window (ms).
ONLINE_WINDOW_MS=300000

# Indexer poll interval (ms).
