# ---- NeuroSync stack env (copy to .env on the server; .env is gitignored) ----

# Postgres password for the bundled db service.
POSTGRES_PASSWORD=change-me

# Upstream Solana RPC. Server-side only, surfaced to the browser solely through
# the /api/rpc proxy. Use a Helius / QuickNode mainnet URL with your key.
SOLANA_RPC=https://api.mainnet-beta.solana.com

# On-chain program id. Leave EMPTY until the program is deployed. While empty the
# site runs in pre-launch mode: browsing works, registration is disabled.
PROGRAM_ID=
